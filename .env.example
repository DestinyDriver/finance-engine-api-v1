NODE_ENV=development
PORT=3000
API_VERSION=v1

DATABASE_URL="postgresql://financeuser:financepass@localhost:5432/financedb?schema=public"

REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

BCRYPT_ROUNDS=12

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

CORS_ORIGIN="http://localhost:3001"

LOG_LEVEL=debug
LOG_DIR=./logs

DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

CACHE_TTL_SUMMARY=300
CACHE_TTL_TRENDS=600
